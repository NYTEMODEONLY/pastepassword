{
  "$schema": "https://raw.githubusercontent.com/nickel-org/nickel.rs/master/data/tauri-schema.json",
  "productName": "PastePassword",
  "version": "0.1.0",
  "identifier": "com.pastepassword.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "PastePassword",
        "width": 1000,
        "height": 650,
        "minWidth": 800,
        "minHeight": 500,
        "resizable": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "copyright": "Built by nytemode — nytemode.com",
    "shortDescription": "Lightweight, local-only credential manager",
    "longDescription": "A lightweight, local-only credential manager for developers. Built by nytemode.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "infoPlist": "Info.plist"
    }
  }
}
